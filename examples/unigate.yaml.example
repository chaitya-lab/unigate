# Unigate Configuration Example
# Copy this to unigate.yaml and fill in your values

unigate:
  mount_prefix: /unigate
  max_concurrent_processing: 50

storage:
  # Storage backends:
  # - memory: In-memory only (no persistence, good for dev/testing)
  # - sqlite: SQLite database (good for single instance)
  # - file: File-per-message (good for multi-instance, NFS, cloud storage)
  backend: sqlite
  path: ./unigate_data
  
  # Retention settings (for sqlite and file backends):
  # After this many days, sent messages are auto-deleted
  retention_days: 7
  # Dedup keys are kept for this many days
  dedup_retention_days: 1
  # How often to run cleanup (seconds)
  cleanup_interval_seconds: 3600

deduplication:
  window_seconds: 300

instances:
  # Telegram bot example
  my_telegram_bot:
    type: telegram
    token: !env:TELEGRAM_BOT_TOKEN
    mode: polling  # or webhook (requires public URL)
    # webhook_url: https://yourdomain.com/unigate/webhook/telegram
    # webhook_secret: your-secret-token

  # Another Telegram bot (different instance)
  support_bot:
    type: telegram
    token: !env:SUPPORT_BOT_TOKEN
    mode: polling

  # Web UI for testing (no auth needed)
  web:
    type: webui

  # Webhook with API key
  api_channel:
    type: web
    auth_method: api_key
    api_key: !env:API_KEY

  # Webhook with Bearer token
  auth_channel:
    type: web
    auth_method: bearer
    bearer_token: !env:BEARER_TOKEN

# Extension configuration
extensions:
  - name: log
    priority: 100
